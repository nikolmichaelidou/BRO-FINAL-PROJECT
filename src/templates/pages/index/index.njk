{% extends "layouts/base.njk" %}

{% block content %}

<section class="hero">
    <div class="hero-content">
        <div class="hero-text">
            <h1>
                Craft Your<br>
                Success with<br>
                Our <span class="hero__highlight">Digital</span> Assets
            </h1>
            <p>From our inspiring illustrations to dynamic UI/UX kits, elevate your projects with our premium digital design resources.</p>
        </div>
        <div class="hero-buttons">
            <a href="#" class="hero__btn hero__btn--primary">
                {% include "partials/svg-btn-primary-index.njk" %}
            </a>
            <a href="#" class="hero__btn hero__btn--secondary">
                {% include "partials/svg-btn-secondary-index.njk" %}
            </a>
        </div>
    </div>
    <div class="hero-images">
        <div class="hero-gallery">
            <div class="hero-gallery-item">
                <img src="#" alt="Event Website Mockup" class="hero__gallery-img">
            </div>
        </div>
    </div>
</section>

<section class="illustrations">
    {% include "partials/svg-illustrations-index.njk" %}
</section>

<section class="products">
    <div class="product-list">
        {% set products = [
            { img: "img/Illustration-ui-kit.png", alt: "UI Kits", label: "UI Kits" },
            { img: "img/Illustration-social-media.png", alt: "Social Media", label: "Social Media" },
            { img: "img/Illustration-presentations.png", alt: "Presentation", label: "Presentation" },
            { img: "img/Illustration-fonts.png", alt: "Fonts", label: "Fonts" },
            { img: "img/Illustration-icon.png", alt: "Illustrations", label: "Illustrations" }
        ] %}
        {% for product in products %}
            <div class="products__item">
                <img src="{{ product.img }}" alt="{{ product.alt }}" class="products__img">
                <div class="products__label">{{ product.label }}</div>
            </div>
        {% endfor %}
    </div>
</section>

{% endblock %}

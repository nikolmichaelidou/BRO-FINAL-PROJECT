{% extends "layouts/base.njk" %}

{% block content %}

<section class="hero">
    <div class="hero__content">
        <div class="hero__text">
            <h1 class="hero__title">
                Craft Your<br>
                Success with<br>
                Our <span class="hero__highlight">Digital</span> Assets
            </h1>
            <p class="hero__desc">From our inspiring illustrations to dynamic UI/UX kits, elevate your projects with our premium digital design resources.</p>
        </div>
        <div class="hero__actions">
            <a href="#" class="hero__btn hero__btn--primary">
                {% include "partials/svg-btn-primary-index.njk" %}
            </a>
            <a href="#" class="hero__btn hero__btn--secondary">
                {% include "partials/svg-btn-secondary-index.njk" %}
            </a>
        </div>
    </div>
    <div class="hero__images">
        <div class="hero__gallery">
            <div class="hero__gallery-item">
                <img src="#" alt="Event Website Mockup" class="hero__gallery-img">
            </div>
        </div>
    </div>
</section>

<section class="illustrations">
    {% include "partials/svg-illustrations-index.njk" %}
</section>

<br>

<section class="products">
    <div class="product-list">
       <div class="product-list__collum">
        {% include "partials/svg-products-index.njk" %}
       </div>
    </div>
    <div class="categories-section">
        <span class="categories-section__label">
            CATEGORIES
        </span>
        <h2 class="categories-section__title">
            Discover Assets for<br>
            Every Projects
        </h2>
        <p class="categories-section__desc">
            From fonts and icons to mockups and templates, our comprehensive categories ensure that you find exactly what you need to your projects.
        </p>
        <a href="#" class="categories-section__btn">
            Shop Now
        </a>
    </div>
</section>

<section class="trending-products">
  <div class="trending-products__header">
    <span class="trending-products__trending">TRENDING</span>
    <h2 class="trending-products__title">Trending Products</h2>
    <div class="trending-products__nav">
      <button class="trending-products__nav-btn" aria-label="Previous">
        &lt;
      </button>
      <button class="trending-products__nav-btn" aria-label="Next">
        &gt;
      </button>
    </div>
  </div>
  <div class="trending-products__list">
    <div class="product-card">
      <div class="product-card__image" style="background:#FFE9B3;">
        <img src="images/travel-hero.png" alt="Travel Hero" />
        <span class="product-card__badge">HERO SECTION</span>
      </div>
      <div class="product-card__info">
        <div class="product-card__name">Travel Hero</div>
        <div class="product-card__price">€29.99</div>
        <div class="product-card__tags">
          <span>Adventure</span> • <span>Journey</span>
        </div>
      </div>
    </div>
    <div class="product-card product-card--active">
      <div class="product-card__image" style="background:#E6F0FA;">
        <img src="images/healthcare-pro.png" alt="Healthcare Pro" />
        <span class="product-card__badge product-card__badge--trophy">
          <svg><!-- trophy icon --></svg>
        </span>
        <button class="product-card__cta">Go to product</button>
      </div>
      <div class="product-card__info">
        <div class="product-card__name">Healthcare Pro</div>
        <div class="product-card__price">€39.99</div>
        <div class="product-card__tags">
          <span>Medical</span> • <span>Wellness</span>
        </div>
      </div>
    </div>
    <div class="product-card">
      <div class="product-card__image" style="background:#E6FAD7;">
        <img src="images/foodish-delight.png" alt="Foodish Delight" />
        <span class="product-card__badge">HERO SECTION</span>
      </div>
      <div class="product-card__info">
        <div class="product-card__name">Foodish Delight</div>
        <div class="product-card__price">€31.99</div>
        <div class="product-card__tags">
          <span>Catering</span> • <span>Food</span>
        </div>
      </div>
    </div>
    <div class="product-card">
      <div class="product-card__image" style="background:#D6F3FF;">
        <img src="images/real-estate.png" alt="Real Estate" />
        <span class="product-card__badge">LANDING PAGE</span>
      </div>
      <div class="product-card__info">
        <div class="product-card__name">Real Estate</div>
        <div class="product-card__price">€40.99</div>
        <div class="product-card__tags">
          <span>Modern</span> • <span>Homes</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
    
</section>    

{% endblock %}

<section class="latest-expert">
  <div class="latest-expert__header">
    <h2 class="latest-expert__title">Latest Expert</h2>
    <a href="#" class="latest-expert__explore">Explore All Articles &rsaquo;</a>
  </div>
  <div class="latest-expert__content">
    <div class="latest-expert__blog-list">
      <div class="blog-card">
        <img src="#" alt="Blog 1" class="blog-card__img">
        <div class="blog-card__meta">
          <span class="blog-card__author">A. Typogreyyer</span>
          <span class="blog-card__date">20 Jan 2022</span>
        </div>
        <div class="blog-card__title">Sonic live</div>
        <div class="blog-card__desc">One September 20, 2023 a volutpat nulla eros, nulla ultricies nec nulla imperdiet...</div>
        <a href="#" class="blog-card__btn">Read more &rsaquo;</a>
      </div>
      <!-- Repeat .blog-card for more articles -->
    </div>
    <div class="latest-expert__featured">
      <img src="#" alt="Featured" class="featured-article__img">
      <div class="featured-article__overlay">
        <div class="featured-article__title">THE BEST DISHES</div>
        <div class="featured-article__desc">We have a proper passion for cooking. Love is the secret ingredient that makes all our meals taste better and magical.</div>
        <a href="#" class="featured-article__btn">View More</a>
      </div>
    </div>
  </div>
</section>

<script>
  let questionButton = document.querySelectorAll('.faq-accordion__question');
  questionButton.forEach((elem) => {
    elem.addEventListener("click", () => {
      elem
        .classList
        .toggle("show");
    });
  });
</script>

{%endblock %}
<!-- catalog template -->
{% extends "layouts/base.njk" %}
{% set activeFilters = ['UI Kit', 'UI Kit'] %}
{% block content %}
    <section class="catalog-hero">
        <div class="catalog-hero__container">
            <h1 class="catalog-hero__title">
                Explore Top<br>
                <span class="catalog-hero__highlight">UI Kits</span> Design Assets
            </h1>
        </div>
        <div class="catalog-hero__wave">
            <svg viewBox="0 0 1920 180" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                <path d="M0 60C480 180 1440 0 1920 120V180H0V60Z" fill="#E7ECF0"/>
            </svg>
        </div>
    </section>

    <section class="catalog-flex-wrapper">
        <aside class="catalog-filter">
            <button type="button" class="catalog-filter__close-btn" aria-label="Close filters">
                <span aria-hidden="true">✕</span>
            </button>
            <form>
                <button type="reset" class="catalog-filter__clear-btn">
                    <span>✕</span> Clear all filters
                </button>

                <div class="catalog-filter__section">
                    <h2 class="catalog-filter__title">Categories</h2>
                    <div class="catalog-filter__content">
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox" checked>
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>All Categories</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Technology</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Travel &amp; Tourism</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Health &amp; Fitness</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>E-Commerce</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Education</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Entertainment</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Others</span>
                        </label>
                    </div>
                </div>

                <div class="catalog-filter__section">
                    <h2 class="catalog-filter__title">Format Type</h2>
                    <div class="catalog-filter__content">
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox" checked>
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>All Formats</span>
                            <!-- Changed from All Categories to prevent duplicate text -->
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Figma</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Sketch</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Adobe XD</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Adobe Photoshop</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Adobe Illustration</span>
                        </label>
                        <label class="catalog-filter__checkbox">
                            <input type="checkbox">
                            <span class="catalog-filter__custom-checkbox"></span>
                            <span>Others</span>
                        </label>
                    </div>
                </div>

                <div class="catalog-filter__section">
                    <h2 class="catalog-filter__title">Style</h2>
                    <label class="catalog-filter__toggle">
                        <input type="checkbox" checked>
                        <span>Minimalist</span>
                    </label>
                    <label class="catalog-filter__toggle">
                        <input type="checkbox" checked>
                        <span>Modern</span>
                    </label>
                    <label class="catalog-filter__toggle">
                        <input type="checkbox" checked>
                        <span>Playful</span>
                    </label>
                    <label class="catalog-filter__toggle">
                        <input type="checkbox" checked>
                        <span>Dark Mode</span>
                    </label>
                    <label class="catalog-filter__toggle">
                        <input type="checkbox" checked>
                        <span>Photosentric</span>
                    </label>
                </div>

                <div class="catalog-filter__section">
                    <h2 class="catalog-filter__title">Price</h2>
                    <div class="catalog-filter__slider">
                        <input type="range" min="5" max="50" value="15" class="catalog-filter__range" id="price_range">
                        <span>€5</span>
                        <span>€50</span>
                    </div>
                </div>
            </form>
        </aside>

        <section class="catalog-grid">
            <div class="catalog-header-bar">
                <div class="catalog-header-bar__left">
                    <div class="catalog-sort-dropdown">
                        <button class="catalog-sort-dropdown__btn" id="sort_dropdown_btn">
                Best Seller
                <span class="catalog-sort-dropdown__chevron">&#9662;</span>
                        </button>
                        <div class="catalog-sort-dropdown__menu" id="sort_dropdown">
                            <div class="catalog-sort-dropdown__option catalog-sort-dropdown__option--selected">Best Seller</div>
                            <div class="catalog-sort-dropdown__option">Newest</div>
                            <div class="catalog-sort-dropdown__option">Price: Low to High</div>
                            <div class="catalog-sort-dropdown__option">Price: High to Low</div>
                            <div class="catalog-sort-dropdown__option">Most Popular</div>
                        </div>
                    </div>
                </div>
                <div class="catalog-header-bar__right">
                    <span class="catalog-header-bar__results">Showing 12 out of 120 results.</span>
                    <div class="catalog-header-bar__view-toggle">
                        <button class="catalog-header-bar__view-btn catalog-header-bar__view-btn--active">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path class="catalog-header-bar__view-path" d="M6.4 1H2.6C2.03995 1 1.75992 1 1.54601 1.10899C1.35785 1.20487 1.20487 1.35785 1.10899 1.54601C1 1.75992 1 2.03995 1 2.6V6.4C1 6.96005 1 7.24008 1.10899 7.45399C1.20487 7.64215 1.35785 7.79513 1.54601 7.89101C1.75992 8 2.03995 8 2.6 8H6.4C6.96005 8 7.24008 8 7.45399 7.89101C7.64215 7.79513 7.79513 7.64215 7.89101 7.45399C8 7.24008 8 6.96005 8 6.4V2.6C8 2.03995 8 1.75992 7.89101 1.54601C7.79513 1.35785 7.64215 1.20487 7.45399 1.10899C7.24008 1 6.96005 1 6.4 1Z" stroke="#F8F7FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path class="catalog-header-bar__view-path" d="M17.4 1H13.6C13.0399 1 12.7599 1 12.546 1.10899C12.3578 1.20487 12.2049 1.35785 12.109 1.54601C12 1.75992 12 2.03995 12 2.6V6.4C12 6.96005 12 7.24008 12.109 7.45399C12.2049 7.64215 12.3578 7.79513 12.546 7.89101C12.7599 8 13.0399 8 13.6 8H17.4C17.9601 8 18.2401 8 18.454 7.89101C18.6422 7.79513 18.7951 7.64215 18.891 7.45399C19 7.24008 19 6.96005 19 6.4V2.6C19 2.03995 19 1.75992 18.891 1.54601C18.7951 1.35785 18.6422 1.20487 18.454 1.10899C18.2401 1 17.9601 1 17.4 1Z" stroke="#F8F7FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path class="catalog-header-bar__view-path" d="M17.4 12H13.6C13.0399 12 12.7599 12 12.546 12.109C12.3578 12.2049 12.2049 12.3578 12.109 12.546C12 12.7599 12 13.0399 12 13.6V17.4C12 17.9601 12 18.2401 12.109 18.454C12.2049 18.6422 12.3578 18.7951 12.546 18.891C12.7599 19 13.0399 19 13.6 19H17.4C17.9601 19 18.2401 19 18.454 18.891C18.6422 18.7951 18.7951 18.6422 18.891 18.454C19 18.2401 19 17.9601 19 17.4V13.6C19 13.0399 19 12.7599 18.891 12.546C18.7951 12.3578 18.6422 12.2049 18.454 12.109C18.2401 12 17.9601 12 17.4 12Z" stroke="#F8F7FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path class="catalog-header-bar__view-path" d="M6.4 12H2.6C2.03995 12 1.75992 12 1.54601 12.109C1.35785 12.2049 1.20487 12.3578 1.10899 12.546C1 12.7599 1 13.0399 1 13.6V17.4C1 17.9601 1 18.2401 1.10899 18.454C1.20487 18.6422 1.35785 18.7951 1.54601 18.891C1.75992 19 2.03995 19 2.6 19H6.4C6.96005 19 7.24008 19 7.45399 18.891C7.64215 18.7951 7.79513 18.6422 7.89101 18.454C8 18.2401 8 17.9601 8 17.4V13.6C8 13.0399 8 12.7599 7.89101 12.546C7.79513 12.3578 7.64215 12.2049 7.45399 12.109C7.24008 12 6.96005 12 6.4 12Z" stroke="#F8F7FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                        <button class="catalog-header-bar__view-btn">
                            <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path class="catalog-header-bar__view-path" d="M19 8L7 8M19 2L7 2M19 14L7 14M3 8C3 8.55228 2.55228 9 2 9C1.44772 9 1 8.55228 1 8C1 7.44772 1.44772 7 2 7C2.55228 7 3 7.44772 3 8ZM3 2C3 2.55228 2.55228 3 2 3C1.44772 3 1 2.55228 1 2C1 1.44772 1.44772 1 2 1C2.55228 1 3 1.44772 3 2ZM3 14C3 14.5523 2.55228 15 2 15C1.44772 15 1 14.5523 1 14C1 13.4477 1.44772 13 2 13C2.55228 13 3 13.4477 3 14Z" stroke="#0D0D15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="catalog-active-filters">
                {% for filter in activeFilters %}
                    <button class="catalog-active-filters__tag">
                        {{ filter }}
                        <span class="catalog-active-filters__remove">&#10005;</span>
                    </button>
                {% endfor %}
            </div>

            <div class="catalog-grid__products">
                {% for item in product %}
                    <div class="catalog-grid__card {% if item.badge == 'SOLD OUT' %}catalog-grid__card--sold-out{% endif %}">
                        {% if item.badge %}
                            <span class="catalog-grid__badge catalog-grid__badge--{{ item.badge | lower | replace(" ", "-") }}">{{ item.badge }}</span>
                        {% endif %}
                        <img src="{{ item.image }}" alt="{{ item.title }}" class="catalog-grid__image">
                        <div class="catalog-grid__info">
                            <div class="catalog-grid__title">{{ item.title }}</div>
                            <div class="catalog-grid__category">{{ item.category }}</div>
                            <div class="catalog-grid__price-wrapper">
                                <div class="catalog-grid__price">{{ item.price }}</div>
                                <div class="catalog-grid__actions">
                                    <button class="catalog-grid__wishlist-btn">
                                        <span class="catalog-grid__icon-heart"></span></button>
                                    <button class="catalog-grid__cart-btn">
                                        <span class="catalog-grid__icon-bag"></span></button>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <!-- Normal state -->
            <button class="catalog-grid__load-more">Load more</button>
        </section>
    </section>

    <!-- Add mobile filter toggle button -->
    <button class="catalog-filter__mobile-toggle">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path class="catalog-filter__toggle-icon" d="M3 9H15M6 3H12M9 15H12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Filters
    </button>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Load more button functionality
            const loadMoreBtn = document.querySelector('.catalog-grid__load-more:not(.catalog-grid__load-more--loading):not(.catalog-grid__load-more--disabled)');
            if (loadMoreBtn) {
                loadMoreBtn.addEventListener('click', function() {
                    // Simulate loading state
                    this.classList.add('catalog-grid__load-more--loading');
                    this.textContent = 'Loading...';
                    
                    // Simulate API call delay
                    setTimeout(() => {
                        // After "loading" completes
                        this.classList.remove('catalog-grid__load-more--loading');
                        this.classList.add('catalog-grid__load-more--disabled');
                        this.textContent = 'No more items';
                    }, 2000);
                });
            }
            
            // Filter sections toggle functionality

            // Filter sections toggle
            const filterTitles = document.querySelectorAll('.catalog-filter__title');
            filterTitles.forEach(title => {
                title.addEventListener('click', function () {
                    const targetId = this.getAttribute('data-toggle');

                    // Make sure we have a valid target ID
                    if (targetId) {
                        const targetContent = document.getElementById(targetId);

                        // Only toggle classes if the target content exists
                        if (targetContent) {
                            this
                                .classList
                                .toggle('catalog-filter__title--collapsed');
                            targetContent
                                .classList
                                .toggle('catalog-filter__content--collapsed');
                        }
                    } else {
                        // If no data-toggle attribute, toggle next sibling (assuming it's the content)
                        const targetContent = this.nextElementSibling;
                        if (targetContent && targetContent.classList.contains('catalog-filter__content')) {
                            this
                                .classList
                                .toggle('catalog-filter__title--collapsed');
                            targetContent
                                .classList
                                .toggle('catalog-filter__content--collapsed');
                        }
                    }
                });
            });
        });
    </script>
{% endblock %}
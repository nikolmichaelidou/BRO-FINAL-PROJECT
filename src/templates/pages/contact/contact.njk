{% extends "layouts/base.njk" %}
{% block content %}
<section class="contact-section">
  <span class="contact-section__label">CONTACT</span>
  <h1 class="contact-section__title">Get in Touch<br>with Us</h1>
  <p class="contact-section__desc">
    We are here to help you navigate your creative journey. Reach out for any questions, support, or feedback.
  </p>
  <a href="#" class="contact-section__btn">Shop Now</a>
  <div class="contact-section__info">
    <div class="contact-section__info-item">
      <img src="#" alt="Phone" class="contact-section__icon">
      <span>+1 (555) 123-4567</span>
    </div>
    <div class="contact-section__info-item">
      <img src="#" alt="Email" class="contact-section__icon">
      <span>support@pixmart.com</span>
    </div>
    <div class="contact-section__info-item">
      <img src="#" alt="Clock" class="contact-section__icon">
      <span>Monday to Friday : 9 AM - 5 PM EST</span>
    </div>
  </div>
  <div class="contact-section__map">
    <img src="/svg-map.njk" alt="Map" class="contact-section__map-img">
    <div class="contact-section__map-card">
      <strong>PixMart HQ</strong><br>
      123 Creative Ave, Design City, 45678
    </div>
  </div>
</section>
{% endblock %}
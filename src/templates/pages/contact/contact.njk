<!-- contact template -->
{% extends "layouts/base.njk" %}
{% block content %}
  <main class="contact-layout-wrapper">
    <section class="contact-section">
      <p class="contact-section__label">CONTACT</p>
      <h1 class="contact-section__title">Get in Touch<br>with Us</h1>
      <p class="contact-section__desc">
        We are here to help you navigate your creative journey. Reach out for any questions, support, or feedback.
      </p>
      <a href="#" class="contact-section__btn">Shop Now</a>
      <div class="contact-section__info">
        <div class="contact-section__info-item">
          <svg class="contact-section__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7.38028 7.85335C8.07627 9.30297 9.02506 10.6616 10.2266 11.8632C11.4282 13.0648 12.7869 14.0136 14.2365 14.7096C14.3612 14.7694 14.4235 14.7994 14.5024 14.8224C14.7828 14.9041 15.127 14.8454 15.3644 14.6754C15.4313 14.6275 15.4884 14.5704 15.6027 14.4561C15.9523 14.1064 16.1271 13.9316 16.3029 13.8174C16.9658 13.3864 17.8204 13.3864 18.4833 13.8174C18.6591 13.9316 18.8339 14.1064 19.1835 14.4561L19.3783 14.6509C19.9098 15.1824 20.1755 15.4481 20.3198 15.7335C20.6069 16.301 20.6069 16.9713 20.3198 17.5389C20.1755 17.8242 19.9098 18.09 19.3783 18.6214L19.2207 18.779C18.6911 19.3087 18.4263 19.5735 18.0662 19.7757C17.6667 20.0001 17.0462 20.1615 16.588 20.1601C16.1751 20.1589 15.8928 20.0788 15.3284 19.9186C12.295 19.0576 9.43264 17.4332 7.04466 15.0452C4.65668 12.6572 3.03221 9.79483 2.17124 6.76144C2.01103 6.19699 1.93092 5.91477 1.9297 5.50182C1.92833 5.0436 2.08969 4.42311 2.31411 4.0236C2.51636 3.66357 2.78117 3.39876 3.3108 2.86913L3.46843 2.7115C3.99987 2.18006 4.2656 1.91433 4.55098 1.76999C5.11854 1.48292 5.7888 1.48292 6.35636 1.76999C6.64174 1.91433 6.90747 2.18006 7.43891 2.7115L7.63378 2.90637C7.98338 3.25597 8.15819 3.43078 8.27247 3.60655C8.70347 4.26945 8.70347 5.12403 8.27247 5.78692C8.15819 5.96269 7.98338 6.1375 7.63378 6.4871C7.51947 6.60142 7.46231 6.65857 7.41447 6.72538C7.24446 6.96281 7.18576 7.30707 7.26748 7.58743C7.29048 7.66632 7.32041 7.72866 7.38028 7.85335Z" stroke="#0265DC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>+1 (555) 123-4567</span>
        </div>
        <div class="contact-section__info-item">
          <svg class="contact-section__icon" width="22" height="18" viewBox="0 0 22 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 4L9.16492 9.71544C9.82609 10.1783 10.1567 10.4097 10.5163 10.4993C10.8339 10.5785 11.1661 10.5785 11.4837 10.4993C11.8433 10.4097 12.1739 10.1783 12.8351 9.71544L21 4M5.8 17H16.2C17.8802 17 18.7202 17 19.362 16.673C19.9265 16.3854 20.3854 15.9265 20.673 15.362C21 14.7202 21 13.8802 21 12.2V5.8C21 4.11984 21 3.27976 20.673 2.63803C20.3854 2.07354 19.9265 1.6146 19.362 1.32698C18.7202 1 17.8802 1 16.2 1H5.8C4.11984 1 3.27976 1 2.63803 1.32698C2.07354 1.6146 1.6146 2.07354 1.32698 2.63803C1 3.27976 1 4.11984 1 5.8V12.2C1 13.8802 1 14.7202 1.32698 15.362C1.6146 15.9265 2.07354 16.3854 2.63803 16.673C3.27976 17 4.11984 17 5.8 17Z" stroke="#0265DC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>support@pixmart.com</span>
        </div>
        <div class="contact-section__info-item">
          <svg class="contact-section__icon" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 5V11L15 13M21 11C21 16.5228 16.5228 21 11 21C5.47715 21 1 16.5228 1 11C1 5.47715 5.47715 1 11 1C16.5228 1 21 5.47715 21 11Z" stroke="#0265DC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Monday to Friday : 9 AM - 5 PM EST</span>
        </div>
      </div>
      <div class="contact-section__map">
        <img src="img/map-screenshot-2x.webp" alt="Map" class="contact-section__map-image">
      </div>
    </section>

    <section class="contact-form-section">
      <form class="contact-form">
        <label for="fullName" class="contact-form__label">Full Name</label>
        <input type="text" id="fullName" name="fullName" class="contact-form__input" placeholder="Amelia Robert Johnson" required>

        <label for="email" class="contact-form__label">Email Address</label>
        <input type="email" id="email" name="email" class="contact-form__input" placeholder="amelia.robertjohnson@pixmart.com" required>

        <label for="subject" class="contact-form__label">Subject</label>
        <select id="subject" name="subject" class="contact-form__input">
          <option>General Inquiry</option>
          <option>Support</option>
          <option>Feedback</option>
          <option>Other</option>
        </select>

        <label for="message" class="contact-form__label">Message</label>
        <textarea id="message" name="message" class="contact-form__input" placeholder="Enter your message ..." required></textarea>

        <div class="contact-form__bottom">
          <div class="contact-form__options">
            <label class="contact-form__checkbox">
              <input type="checkbox" name="newsletter">
              <span>Subscribe me to Newsletter</span>
            </label>
            <label class="contact-form__checkbox">
              <input type="checkbox" name="privacy" required checked>
              <span>I have read the User & Privacy Policy</span>
            </label>
          </div>
          <button type="submit" class="contact-form__btn">Send Message</button>
        </div>
      </form>
    </section>
  </main>
{% endblock %}
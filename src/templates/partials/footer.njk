<link rel="stylesheet" href="/css/style.css">
<footer class="footer">
  <div class="footer__main">
    <div class="footer__brand">
      <div class="footer__logo">Pixmart<span class="footer__dot">.</span></div>
      <div class="footer__desc">Your premium digital assets solution with high quality and comprehensive range of products and services.</div>
      <div class="footer__socials">
        <a href="#" class="footer__social"><img src="#" alt="Twitter"></a>
        <a href="#" class="footer__social"><img src="#" alt="Facebook"></a>
        <a href="#" class="footer__social"><img src="#" alt="Telegram"></a>
      </div>
    </div>
    <div class="footer__links">
      {% for col in footerLinks %}
        <div class="footer__col">
          <div class="footer__title">{{ col.title }}</div>
          {% for link in col.links %}
            <a href="#" class="footer__link">{{ link }}</a>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
    <div class="footer__newsletter">
      <div class="footer__newsletter-title">Subscribe to<br>Design Newsletter</div>
      <form class="footer__newsletter-form">
        <input type="email" class="footer__newsletter-input" placeholder="Enter your email address ..." required>
        <button type="submit" class="footer__newsletter-btn">Subscribe</button>
      </form>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="footer__bottom-links">
      <a href="#" class="footer__bottom-link">Privacy Policy</a>
      <span class="footer__bottom-separator">|</span>
      <a href="#" class="footer__bottom-link">Terms and Condition</a>
      <span class="footer__bottom-separator">|</span>
      <a href="#" class="footer__bottom-link">Site Map</a>
    </div>
    <div class="footer__copyright">
      Copyright © 2024 Pixmart. All rights reserved.
    </div>
  </div>
</footer>
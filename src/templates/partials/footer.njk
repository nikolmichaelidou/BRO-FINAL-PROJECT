            <path d="M23.5468 0.422732C23.1374 0.114515 22.4944 0.0704154 21.8295 0.307393H21.8285C21.1292 0.556486 2.03537 7.82768 1.25808 8.12475C1.11671 8.16836 -0.118008 8.57738 0.00917513 9.48846C0.122712 10.3099 1.11507 10.6501 1.23625 10.6893L6.0905 12.165C6.41255 13.1168 7.59977 16.6283 7.86233 17.3785C8.02608 17.8462 8.293 18.4607 8.7608 18.5871C9.17128 18.7277 9.57957 18.5993 9.84376 18.4151L12.8116 15.9712L17.6025 19.2884L17.7166 19.349C18.0419 19.4769 18.3536 19.5409 18.6511 19.5409C18.8809 19.5409 19.1014 19.5026 19.3121 19.426C20.0299 19.1643 20.317 18.5571 20.347 18.4883L23.9256 1.97399C24.144 1.09199 23.8405 0.643232 23.5468 0.422732ZM10.3716 12.7553L8.73405 16.6322L7.0965 11.786L19.6511 3.54754L10.3716 12.7553Z" fill="#0D0D15"/>

      </div>
    </div>
    <div class="footer__links">
      {% for col in footerLinks %}
        <div class="footer__col">
          <div class="footer__title">{{ col.title }}</div>
          {% for link in col.links %}
            <a href="#" class="footer__link">{{ link }}</a>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
    <div class="footer__newsletter">
      <div class="footer__newsletter-title">Subscribe to<br>Design Newsletter</div>
      <form class="footer__newsletter-form">
        <input type="email" class="footer__newsletter-input" placeholder="Enter your email address ..." required>
        <button type="submit" class="footer__newsletter-btn">Subscribe</button>
      </form>
    </div>
  </div>
  {% include "partials/svg-footer-bottom.njk" %}
</footer>
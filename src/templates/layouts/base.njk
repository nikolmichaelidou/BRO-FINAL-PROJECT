<!-- Pixmart Base Template -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} - {% endif %}Pixmart</title>
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer">
  </head>
  <body>
    {% include "partials/header.njk" %}
    <main>
      {% block content %}default content{% endblock %}
    </main>
    {% include "partials/footer.njk" %}
    
    <!-- Add JavaScript for mobile menu functionality -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Burger menu toggle
            const burgerBtn = document.querySelector('.navbar__burger');
            const mobileMenu = document.querySelector('.navbar__links');
            
            if(burgerBtn && mobileMenu) {
                burgerBtn.addEventListener('click', function() {
                    burgerBtn.classList.toggle('navbar__burger--open');
                    mobileMenu.classList.toggle('navbar__links--open');
                    // Prevent scrolling when menu is open
                    document.body.classList.toggle('menu-open');
                });
                
                // Close menu when clicking outside
                document.addEventListener('click', function(e) {
                    if (!burgerBtn.contains(e.target) && 
                        !mobileMenu.contains(e.target) && 
                        mobileMenu.classList.contains('navbar__links--open')) {
                        burgerBtn.classList.remove('navbar__burger--open');
                        mobileMenu.classList.remove('navbar__links--open');
                        document.body.classList.remove('menu-open');
                    }
                });
                
                // Close menu when ESC key is pressed
                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && mobileMenu.classList.contains('navbar__links--open')) {
                        burgerBtn.classList.remove('navbar__burger--open');
                        mobileMenu.classList.remove('navbar__links--open');
                        document.body.classList.remove('menu-open');
                    }
                });
            }
            
            // Filter toggle for mobile
            const filterToggleBtn = document.querySelector('.catalog-filter__mobile-toggle') || 
                                    document.querySelector('.filter-mobile-toggle');
            const filterPanel = document.querySelector('.catalog-filter');
            
            if(filterToggleBtn && filterPanel) {
                // Check if close button already exists
                let closeBtn = filterPanel.querySelector('.filter-close-btn') || 
                               filterPanel.querySelector('.catalog-filter__close-btn');
                               
                // Create close button if it doesn't exist
                if (!closeBtn) {
                    closeBtn = document.createElement('button');
                    closeBtn.classList.add('filter-close-btn');
                    closeBtn.innerHTML = '&times;'; // Using proper HTML entity for the times symbol
                    closeBtn.setAttribute('aria-label', 'Close filter');
                    filterPanel.prepend(closeBtn);
                }
                
                filterToggleBtn.addEventListener('click', function() {
                    filterPanel.classList.add('active');
                    filterPanel.classList.add('catalog-filter--active');
                    document.body.classList.add('filter-open');
                });
                
                closeBtn.addEventListener('click', function() {
                    filterPanel.classList.remove('active');
                    filterPanel.classList.remove('catalog-filter--active');
                    document.body.classList.remove('filter-open');
                });
                
                // Close filter when ESC key is pressed
                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape' && 
                        (filterPanel.classList.contains('active') || 
                         filterPanel.classList.contains('catalog-filter--active'))) {
                        filterPanel.classList.remove('active');
                        filterPanel.classList.remove('catalog-filter--active');
                        document.body.classList.remove('filter-open');
                    }
                });
            }
            
            // FAQ Accordion functionality
            const faqButtons = document.querySelectorAll('.faq-accordion__question');
            
            if (faqButtons.length > 0) {
                faqButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const item = this.closest('.faq-accordion__item');
                        
                        // Check if this item is already active
                        const isActive = item.classList.contains('faq-accordion__item--active');
                        
                        // Close all accordion items
                        document.querySelectorAll('.faq-accordion__item').forEach(element => {
                            element.classList.remove('faq-accordion__item--active');
                            element.querySelector('.faq-accordion__question').classList.remove('show');
                        });
                        
                        // If the clicked item wasn't active, open it
                        if (!isActive) {
                            item.classList.add('faq-accordion__item--active');
                            this.classList.add('show');
                        }
                    });
                });
            }
        });
    </script>
  </body>
</html>